<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#A0E91E63"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/displayTxt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="32dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="32dp"
        android:fontFamily="cursive"
        android:text="Hello World!"
        android:textColor="#6A1B9A"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <EditText
        android:id="@+id/editNameTxt"
        android:layout_width="230dp"
        android:layout_height="69dp"
        android:layout_marginStart="65dp"
        android:layout_marginTop="45dp"
        android:layout_marginEnd="65dp"
        android:layout_marginBottom="240dp"
        android:autofillHints=""
        android:ems="10"
        android:fontFamily="cursive"
        android:inputType="text"
        android:text="@string/name"
        android:textColor="#6A1B9A"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@+id/displayTxt"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:ignore="LabelFor" />

    <Button
        android:id="@+id/clickBtn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="169dp"
        android:layout_marginTop="111dp"
        android:layout_marginEnd="152dp"
        android:layout_marginBottom="197dp"
        android:background="#563B5D"
        android:fontFamily="cursive"
        android:text="@string/button"
        android:textColor="#03A9F4"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/displayTxt" />

    <Switch
        android:id="@+id/switchBtn"
        android:layout_width="168dp"
        android:layout_height="48dp"
        android:fontFamily="cursive"
        android:text="Zulu"
        android:textColor="#6A1B9A"
        android:textSize="24sp"
        android:textStyle="bold"
        tools:ignore="HardcodedText,MissingConstraints,TextSizeCheck,UseSwitchCompatOrMaterialXml"
        tools:layout_editor_absoluteX="101dp"
        tools:layout_editor_absoluteY="222dp" />

</androidx.constraintlayout.widget.ConstraintLayout>